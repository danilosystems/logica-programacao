algoritmo "somafuncao"
var
   n1, n2, s: inteiro
   
funcao soma(x, y: inteiro): inteiro
inicio
      retorne (x + y)
fimfuncao
   
inicio
      escreva(" digite um nºmero: ")
      leia(n1)
      escreva(" digite outro nºmero: ")
      leia(n2)
      s <- soma(n1,n2)
      escrevaL(" soma: ", s)
fimalgoritmo