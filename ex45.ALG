algoritmo "passagemparametroporvalor"
var
   x, y: inteiro
procedimento soma(a, b: inteiro)
inicio
      escrevaL(" Recebi o valor: ", a)
      escrevaL(" Recebi o valor: ", b)
      escrevaL(" A soma entre os dois é: ", a + b)
fimprocedimento
inicio
      x <- 5
      y <- 3
      soma(x, y)
fimalgoritmo